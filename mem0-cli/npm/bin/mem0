#!/usr/bin/env node

const path = require("path");
const { execFileSync } = require("child_process");

const ext = process.platform === "win32" ? ".exe" : "";
const binary = path.join(__dirname, `mem0-bin${ext}`);

try {
  require("fs").accessSync(binary);
} catch {
  console.error("mem0 binary not found. Run `npm install` to download it.");
  process.exit(1);
}

try {
  execFileSync(binary, process.argv.slice(2), { stdio: "inherit" });
} catch (err) {
  process.exit(err.status ?? 1);
}
